{
  "name": "plus-one",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "dockerode>uuid": "11.1.1",
      "esbuild": "0.28.1"
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "plus-one": "bin/plus-one.mjs"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "test:unit": "vitest --workspace vitest.workspace.ts run --project unit",
    "test:db": "vitest --workspace vitest.workspace.ts run --project database --no-file-parallelism",
    "test:integration": "vitest --workspace vitest.workspace.ts run --project integration --passWithNoTests",
    "test:acceptance": "vitest --workspace vitest.workspace.ts run --project acceptance --passWithNoTests",
    "dev:mastra": "mastra dev --dir apps/engine/src/mastra",
    "plus-one": "tsx apps/engine/src/cli.ts",
    "install:cli": "bash scripts/install-cli.sh",
    "smoke:orchestrator": "tsx apps/engine/src/smoke-orchestrator.ts",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "tsx packages/database/src/migrations/cli.ts migrate",
    "db:verify": "tsx packages/database/src/migrations/cli.ts verify",
    "db:reset:test": "vitest run --project database --no-file-parallelism"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "22.18.12",
    "@types/pg": "8.15.6",
    "dotenv": "17.2.3",
    "eslint": "9.39.1",
    "fast-check": "4.3.0",
    "mastra": "1.16.0",
    "pg": "8.16.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2",
    "vitest": "3.2.6",
    "zod": "4.1.12"
  },
  "dependencies": {
    "@mastra/core": "1.47.0",
    "@mastra/memory": "1.21.2",
    "@mastra/pg": "1.14.0",
    "tsx": "4.20.6"
  }
}
