NODE_ENV=development
ENGINE_HOST=127.0.0.1
ENGINE_PORT=4111

LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=
ORCHESTRATOR_MODEL=openai/gpt-5
LEAD_MODEL=openai/gpt-5
MAKER_MODEL=openai/gpt-5-mini
CHECKER_MODEL=openai/gpt-5
RESEARCH_MODEL=openai/gpt-5

POSTGRES_DB=plus_one
POSTGRES_PORT=5432
PLUS_ONE_ADMIN_PASSWORD=plus_one_admin_local_only
PLUS_ONE_MIGRATOR_PASSWORD=plus_one_migrator_local_only
PLUS_ONE_ACCOUNTING_PASSWORD=plus_one_accounting_local_only
PLUS_ONE_PLANNING_PASSWORD=plus_one_planning_local_only
PLUS_ONE_OPERATIONS_PASSWORD=plus_one_operations_local_only
PLUS_ONE_QUERY_PASSWORD=plus_one_query_local_only
PLUS_ONE_MEMORY_PASSWORD=plus_one_memory_local_only

DATABASE_ADMIN_URL=postgresql://plus_one_admin:plus_one_admin_local_only@127.0.0.1:5432/plus_one
DATABASE_MIGRATOR_URL=postgresql://plus_one_migrator:plus_one_migrator_local_only@127.0.0.1:5432/plus_one
DATABASE_ACCOUNTING_URL=postgresql://plus_one_accounting:plus_one_accounting_local_only@127.0.0.1:5432/plus_one
DATABASE_PLANNING_URL=postgresql://plus_one_planning:plus_one_planning_local_only@127.0.0.1:5432/plus_one
DATABASE_OPERATIONS_URL=postgresql://plus_one_operations:plus_one_operations_local_only@127.0.0.1:5432/plus_one
DATABASE_QUERY_URL=postgresql://plus_one_query:plus_one_query_local_only@127.0.0.1:5432/plus_one
